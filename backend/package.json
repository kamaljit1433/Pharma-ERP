{
  "name": "@ems/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Employee Management System - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:make": "knex migrate:make --knexfile knexfile.js -x ts",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "knex migrate:status --knexfile knexfile.js",
    "seed:make": "knex seed:make --knexfile knexfile.js -x ts",
    "seed:run": "knex seed:run --knexfile knexfile.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600",
    "@aws-sdk/client-ses": "^3.600",
    "@aws-sdk/s3-request-presigner": "^3.600",
    "@sendgrid/mail": "^8.1",
    "axios": "^1.7",
    "bcrypt": "^6.0",
    "compression": "^1.8",
    "connect-redis": "^9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4",
    "express": "^5.1",
    "express-session": "^1.18",
    "firebase-admin": "^12.0",
    "handlebars": "^4.7",
    "helmet": "^7.1",
    "ioredis": "^5.8",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1",
    "mime-types": "^2.1.35",
    "morgan": "^1.10",
    "multer": "^2.0.2",
    "nodemailer": "^7.0",
    "passport": "^0.7",
    "passport-google-oauth20": "^2.0",
    "passport-local": "^1.0",
    "pg": "^8.16",
    "qrcode": "^1.5",
    "speakeasy": "^2.0",
    "tslib": "^2.8.1",
    "uuid": "^10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^2.1.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.0",
    "@typescript-eslint/parser": "^8.0",
    "eslint": "^8.0",
    "fast-check": "^3.20",
    "jest": "^30",
    "prettier": "^3.2",
    "supertest": "^7.0",
    "ts-jest": "^29.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20",
    "typescript": "^5.9"
  }
}
