<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leave Request - {{employeeName}}</title>
    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #0A0A0A;
            background-color: #FFFFFF;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            text-align: center;
            padding: 40px 0;
            border-bottom: 1px solid #E5E5E5;
        }
        .logo {
            font-size: 24px;
            font-weight: 600;
            color: #171717;
        }
        .content {
            padding: 40px 0;
        }
        .request-title {
            font-size: 24px;
            font-weight: 600;
            color: #171717;
            margin-bottom: 20px;
        }
        .request-info {
            background-color: #F5F5F5;
            padding: 20px;
            border-radius: 8px;
            margin: 20px 0;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        .info-label {
            font-weight: 500;
            color: #737373;
        }
        .info-value {
            font-weight: 600;
            color: #171717;
        }
        .reason-section {
            margin: 20px 0;
        }
        .reason-text {
            background-color: #F5F5F5;
            padding: 15px;
            border-radius: 6px;
            font-style: italic;
        }
        .action-buttons {
            text-align: center;
            margin: 30px 0;
        }
        .approve-button {
            display: inline-block;
            background-color: #10B981;
            color: #FAFAFA;
            padding: 12px 24px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 500;
            margin: 0 10px;
        }
        .reject-button {
            display: inline-block;
            background-color: #EF4444;
            color: #FAFAFA;
            padding: 12px 24px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 500;
            margin: 0 10px;
        }
        .footer {
            text-align: center;
            padding: 20px 0;
            border-top: 1px solid #E5E5E5;
            color: #737373;
            font-size: 14px;
        }
        .pending-badge {
            display: inline-block;
            background-color: #FB923C;
            color: #171717;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">Employee Management System</div>
        </div>
        
        <div class="content">
            <h1 class="request-title">Leave Request <span class="pending-badge">Pending Approval</span></h1>
            
            <p>Dear {{managerName}},</p>
            
            <p>{{employeeName}} has submitted a leave request that requires your approval:</p>
            
            <div class="request-info">
                <div class="info-row">
                    <span class="info-label">Employee:</span>
                    <span class="info-value">{{employeeName}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Leave Type:</span>
                    <span class="info-value">{{leaveType}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">From Date:</span>
                    <span class="info-value">{{fromDate}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">To Date:</span>
                    <span class="info-value">{{toDate}}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Total Days:</span>
                    <span class="info-value">{{days}} day(s)</span>
                </div>
            </div>
            
            <div class="reason-section">
                <h3>Reason for Leave:</h3>
                <div class="reason-text">{{reason}}</div>
            </div>
            
            <div class="action-buttons">
                <a href="{{approvalUrl}}" class="approve-button">Review Request</a>
            </div>
            
            <p>Please review and approve/reject this request at your earliest convenience.</p>
        </div>
        
        <div class="footer">
            <p>This is an automated message from the Employee Management System.</p>
        </div>
    </div>
</body>
</html>