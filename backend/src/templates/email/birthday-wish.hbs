<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday {{employeeName}}!</title>
    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #0A0A0A;
            background-color: #FFFFFF;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            text-align: center;
            padding: 40px 0;
            border-bottom: 1px solid #E5E5E5;
        }
        .logo {
            font-size: 24px;
            font-weight: 600;
            color: #171717;
        }
        .content {
            padding: 40px 0;
            text-align: center;
        }
        .birthday-title {
            font-size: 32px;
            font-weight: 700;
            color: #171717;
            margin-bottom: 20px;
        }
        .birthday-emoji {
            font-size: 48px;
            margin: 20px 0;
        }
        .birthday-message {
            font-size: 18px;
            color: #737373;
            margin: 20px 0;
            line-height: 1.8;
        }
        .celebration-box {
            background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
            border: 2px solid #F59E0B;
            padding: 30px;
            border-radius: 12px;
            margin: 30px 0;
        }
        .celebration-text {
            font-size: 20px;
            font-weight: 600;
            color: #92400E;
            margin-bottom: 10px;
        }
        .company-message {
            font-size: 16px;
            color: #92400E;
        }
        .footer {
            text-align: center;
            padding: 20px 0;
            border-top: 1px solid #E5E5E5;
            color: #737373;
            font-size: 14px;
        }
        .wishes {
            font-size: 16px;
            color: #171717;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">{{companyName}}</div>
        </div>
        
        <div class="content">
            <div class="birthday-emoji">🎉🎂🎈</div>
            
            <h1 class="birthday-title">Happy Birthday, {{employeeName}}!</h1>
            
            <div class="celebration-box">
                <div class="celebration-text">Wishing you a wonderful day!</div>
                <div class="company-message">
                    {{#if message}}
                        {{message}}
                    {{else}}
                        May this special day bring you joy, happiness, and all the things you love. Thank you for being such a valuable part of our team!
                    {{/if}}
                </div>
            </div>
            
            <div class="wishes">
                Hope your birthday is filled with laughter, joy, and all your favorite things! 🌟
            </div>
            
            <div class="birthday-message">
                From all of us at {{companyName}}, we hope you have a fantastic birthday and a wonderful year ahead!
            </div>
        </div>
        
        <div class="footer">
            <p>Best wishes from the {{companyName}} team! 🎊</p>
        </div>
    </div>
</body>
</html>