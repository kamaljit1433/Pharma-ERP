# CODEOWNERS file for automated review assignment
# 
# This file defines code ownership for different parts of the repository.
# When a pull request modifies files, GitHub automatically requests reviews
# from the designated code owners.
#
# Format: <file-pattern> <owner1> <owner2> ...
# Use GitHub usernames (@username) or team names (@org/team-name)

# Default owners for everything in the repo
# These owners will be requested for review unless a later match takes precedence
* @your-org/dev-team

# Documentation
*.md @your-org/tech-writers
/docs/ @your-org/tech-writers

# Frontend code
/frontend/ @your-org/frontend-team
/frontend/src/components/ @your-org/frontend-team
/frontend/src/pages/ @your-org/frontend-team

# Backend code
/backend/ @your-org/backend-team
/backend/src/services/ @your-org/backend-team
/backend/src/controllers/ @your-org/backend-team

# Database migrations
/backend/migrations/ @your-org/backend-team @your-org/dba-team

# Infrastructure and DevOps
/.github/ @your-org/devops-team
/docker-compose.yml @your-org/devops-team
/Dockerfile @your-org/devops-team
/.env.example @your-org/devops-team

# Configuration files
*.config.js @your-org/dev-team
*.config.ts @your-org/dev-team
tsconfig.json @your-org/dev-team
package.json @your-org/dev-team

# Security-sensitive files
/backend/src/middleware/auth.ts @your-org/security-team
/backend/src/services/encryption.ts @your-org/security-team
/backend/src/utils/crypto.ts @your-org/security-team

# Payroll module (requires finance team review)
/backend/src/services/payroll/ @your-org/backend-team @your-org/finance-team
/frontend/src/pages/payroll/ @your-org/frontend-team @your-org/finance-team

# Testing
**/*.test.ts @your-org/qa-team
**/*.test.tsx @your-org/qa-team
**/*.spec.ts @your-org/qa-team

# Git configuration
.gitignore @your-org/devops-team
.githooks/ @your-org/devops-team

# Spec files
/.kiro/specs/ @your-org/product-team @your-org/dev-team
